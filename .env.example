# Memerica environment — copy to .env.local and fill with YOUR project's values.
# Use NEW, dedicated accounts for this project; never reuse other projects' keys.
# The app runs entirely on seed data until these are set.

# ── Supabase (Phase 3) ──────────────────────────────────────────────
# From your dedicated Memerica project → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never exposed to the browser
SUPABASE_SERVICE_ROLE_KEY=

# ── AWS S3 + CloudFront (Phase 4) ───────────────────────────────────
# From your dedicated Memerica AWS account (least-privilege IAM user)
AWS_REGION=
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# CloudFront distribution domain that fronts the bucket, e.g. https://dxxxx.cloudfront.net
NEXT_PUBLIC_CDN_URL=
